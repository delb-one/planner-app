rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // This app reads/writes Firestore only from the server via firebase-admin.
    // Server client libraries bypass Firestore Security Rules, so we keep the
    // client surface closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
